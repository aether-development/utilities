{
	"name": "root-utilities",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"build": "nx run-many --target=build --all",
		"clean": "bun run scripts/clean.ts",
		"format": "nx run @aetherjs/prettier-config:build && prettier --write .",
		"lint": "nx run @aetherjs/eslint-config:build && eslint . --fix",
		"prepare": "bun x husky",
		"update": "bun npm-check-updates -p bun -u -ws -i -t latest"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"@favware/cliff-jumper": "^5.0.0",
		"@favware/npm-deprecate": "^2.0.0",
		"@types/bun": "^1.2.9",
		"bun-types": "^1.2.9",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.24.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.0",
		"npm-check-updates": "^17.1.16",
		"nx": "20.7.2",
		"prettier": "^3.5.3",
		"tsup": "^8.4.0",
		"typescript": "~5.8.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aether-development/utilities.git"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"packageManager": "bun@1.1.38"
}
